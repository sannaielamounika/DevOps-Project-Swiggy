pipeline {
    agent any

    environment {
        DOCKER_IMAGE  = "sannaielamounika/swiggyapp"
        DOCKER_CRED   = 'dockerHub-token'
        SONAR_TOKEN   = credentials('sonar-token')
    }

    stages {

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout Code') {
            steps {
                git branch: 'master', url: 'https://github.com/sannaielamounika/DevOps-Project-Swiggy'
            }
        }

        stage('Verify Tools') {
            steps {
                sh '''
                    echo "=== Checking tools ==="
                    java -version
                    node -v
                    npm -v
                    docker --version
                    trivy --version || true
                '''
            }
        }

        stage('Install Dependencies') {
            steps {
                sh '''
                    cd swiggyapp
                    npm install --legacy-peer-deps --force
                '''
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonar-server') {
                    sh '''
                        sonar-scanner \
                        -Dsonar.projectName=swiggyapp \
                        -Dsonar.projectKey=swiggyapp
                    '''
                }
            }
        }

        stage('Quality Gate') {
            steps {
                waitForQualityGate abortPipeline: true
            }
        }

        stage('Trivy File Scan') {
            steps {
                sh '''
                    cd swiggyapp
                    trivy fs . > trivyfs.txt || true
                '''
            }
        }

        stage('Docker Build & Push') {
            steps {
                script {
                    withDockerRegistry(credentialsId: "${DOCKER_CRED}", url: 'https://index.docker.io/v1/') {
                        sh "docker build -t ${DOCKER_IMAGE}:latest ./swiggyapp"
                        sh "docker push ${DOCKER_IMAGE}:latest"
                    }
                }
            }
        }

        stage('Trivy Image Scan') {
            steps {
                sh '''
                    trivy image ${DOCKER_IMAGE}:latest > trivyimage.txt || true
                '''
            }
        }

        stage('Deploy Container') {
            steps {
                sh '''
                    docker stop swiggy || true
                    docker rm swiggy || true
                    docker run -d -p 3000:3000 --name swiggy ${DOCKER_IMAGE}:latest
                '''
            }
        }
    }

    post {
        always {
            echo "Pipeline finished!"

            archiveArtifacts artifacts: 'swiggyapp/trivyfs.txt', allowEmptyArchive: true
            archiveArtifacts artifacts: 'trivyimage.txt', allowEmptyArchive: true
        }
    }
}
