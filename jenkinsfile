pipeline {
    agent any

    stages {
        stage('Test') {
            steps {
                echo "Pipeline working!"

                sh '''
                    pwd
                    ls
                    echo "hello" > test.txt
                '''
            }
        }
    }

    post {
        always {
            echo "Pipeline finished!"
            archiveArtifacts artifacts: 'test.txt', allowEmptyArchive: true
        }
    }
}
