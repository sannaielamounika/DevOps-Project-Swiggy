pipeline {
    agent any
    
    tools {
        jdk 'jdk17'
    }
    
    environment {
        NODE_HOME     = tool 'node23'
        PATH          = "${env.NODE_HOME}/bin:${env.PATH}"
        SCANNER_HOME  = tool 'sonar-scanner'
        DOCKER_IMAGE  = "varaprasadrenati/swiggyapp"
        SONAR_TOKEN   = credentials('sonar-token')
        DOCKER_CRED   = 'dockerHub-token'
        DC_HOME       = tool 'dependency-check'
        DC_CACHE      = '/var/lib/jenkins/Dependency-Check-data'
    }
    
    stages {
        stage('Clean Workspace') {
            steps { cleanWs() }
        }
        
        stage('Checkout Code') {
            steps {
                git branch: 'main', url: 'https://github.com/sannaielamounika/DevOps-Project-Swiggy'
            }
        }
        
        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonar-server') {
                    sh """
                        $SCANNER_HOME/bin/sonar-scanner \
                        -Dsonar.projectName=swiggyapp-CICD \
                        -Dsonar.projectKey=swiggyapp-CICD
                    """
                }
            }
        }
        
        stage('Quality Gate') {
            steps { waitForQualityGate abortPipeline: true }
        }
        
        stage('Install Dependencies') {
            steps {
                sh '''
                    echo "=== Versions ==="
                    java -version
                    node -v
                    npm -v
                    echo "=== Installing npm dependencies ==="
                    cd swiggyapp
                    npm install --legacy-peer-deps --force
                '''
            }
        }
        
        stage('OWASP Dependency-Check') {
            steps {
                script {
                    sh """
                        cd swiggyapp
                        $DC_HOME/bin/dependency-check.sh \
                            --project BookMyShow \
                            --scan package.json \
                            --out owasp-report \
                            --format HTML \
                            --data $DC_CACHE \
                            --threads 4 || true
                    """
                }
            }
        }
        
        stage('Trivy FS Scan') {
            steps {
                sh '''
                    cd swiggyapp
                    trivy fs . > trivyfs.txt || true
                '''
            }
        }
        
        stage('Docker Build & Push') {
            steps {
                script {
                    withDockerRegistry(credentialsId: "${DOCKER_CRED}", url: 'https://index.docker.io/v1/') {
                        sh "docker build -t ${DOCKER_IMAGE}:latest ./swiggyapp"
                        sh "docker push ${DOCKER_IMAGE}:latest"
                    }
                }
            }
        }
        
        stage('Trivy Image Scan') {
            steps {
                sh "trivy image ${DOCKER_IMAGE}:latest > trivyimage.txt || true"
            }
        }
        
        stage('Deploy to Container') {
            steps {
                sh """
                    docker stop swiggy || true
                    docker rm swiggy || true
                    docker run -d -p 3000:3000 --name swiggy ${DOCKER_IMAGE}:latest
                """
            }
        }
    }
    
    post {
        always {
            echo "Pipeline finished!"
            archiveArtifacts artifacts: 'swiggyapp/owasp-report/**/*.*', allowEmptyArchive: true
            archiveArtifacts artifacts: 'trivyfs.txt,trivyimage.txt', allowEmptyArchive: true
        }
    }
}
